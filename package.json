{
	"name": "manifold-lsp",
	"version": "1.0.0",
	"description": "Language Server Protocol implementation for Manifold reactive templating library",
	"main": "out/server.js",
	"scripts": {
		"compile": "tsc -b",
		"compile:watch": "tsc -b --watch",
		"test": "npm run compile && node ./out/test/runTest.js",
		"lint": "eslint src --ext ts",
		"prepare": "npm run compile"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.4",
		"@types/node": "18.x",
		"@typescript-eslint/eslint-plugin": "^7.1.0",
		"@typescript-eslint/parser": "^7.1.0",
		"eslint": "^8.57.0",
		"typescript": "^5.3.3"
	},
	"keywords": [
		"lsp",
		"language-server",
		"manifold",
		"reactive",
		"templating",
		"typescript"
	],
	"author": "",
	"license": "MIT"
}
